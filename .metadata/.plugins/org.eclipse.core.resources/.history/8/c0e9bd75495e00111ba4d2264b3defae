	private JButton getBtnAjouter() {
		if (btnAjouter == null) {
			btnAjouter = new JButton("Ajouter ");
			// --- Bouton Ajouter ---
			btnAjouter.addActionListener(new ActionListener() {
				public void actionPerformed(ActionEvent arg0) {
					String innumeleve = (String) cmbnumEleve.getSelectedItem();
					Eleve eleve = new Eleve(innumeleve);
					
					String innumfiche = (String) txtnumFiche.getText();
					FichePresence fichepresence = new FichePresence(innumfiche);	
					
					
					if (chkpresent.isSelected()){
						Presence presence = new Presence(eleve, fichepresence, "1"
								);
						if ( presence.creerCRUD((String) cmbnumEleve.getSelectedItem(),
								txtnumFiche.getText(),"1")) 
							leModelePresence.creerMOD(presence);
					}else{
						Presence presence = new Presence(eleve, fichepresence, "0"
								);
						if ( presence.creerCRUD((String) cmbnumEleve.getSelectedItem(),
								txtnumFiche.getText(),"0")) 
							leModelePresence.creerMOD(presence);
					}		
					
				}
			});

			btnAjouter.setFont(new Font("Tahoma", Font.BOLD, 12));
			btnAjouter.setBounds(739, 198, 116, 23);
		}
		return btnAjouter;
	}

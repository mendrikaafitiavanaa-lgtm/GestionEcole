	private JButton getBtnVlider() {
		if (btnVlider == null) {
			btnVlider = new JButton("Valider");
			btnVlider.addActionListener(e -> {
				if (txtnumFiche.getText().isEmpty() || datePicker.getDate() == null) {
			        JOptionPane.showMessageDialog(null, "Numéro et date sont obligatoires.");
			        return;
			    }

			    // ⚡ Ici on récupère l’enseignant complet
			    String inenseignant = (String) cmbnumEnseignant.getSelectedItem();
			    if (inenseignant == null || inenseignant.isEmpty()) {
			        JOptionPane.showMessageDialog(null, "Sélectionnez un enseignant.");
			        return;
			    }
			    ArrayList<Enseignant> enseignants = new Enseignant().lireRecupLigne(inenseignant);
			    Enseignant enseignant = enseignants.isEmpty() ? new Enseignant(inenseignant) : enseignants.get(0);

			    // Formatage de la date
			    SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd");
			    String dateSQL = sdf.format(datePicker.getDate());

			    String heureFiche = new SimpleDateFormat("HH:mm").format((Date) heurePresence.getValue());

			    FichePresence fiche = new FichePresence(txtnumFiche.getText(), datePicker.getDate(), heureFiche, enseignant);

			    if(actionDemandee.equals("Ajout")){

					    
					    if (fiche.creerCRUD(
					    		txtnumFiche.getText(), datePicker.getDate(), heureFiche, enseignant.getNumEnseignant())
					    		) {
					        leModeleFichePresence.creerMOD(fiche);
					        JOptionPane.showMessageDialog(null, "Fiche ajoutée avec succès. Date: " + dateSQL +
					                ", Enseignant: " + enseignant.getNomEnseignant());
					    }
			    	}
			    if(actionDemandee.equals("Modifier")){
			    	 int ligne = table.getSelectedRow();
                     if (fiche.modifierCRUD(
                    		 txtnumFiche.getText(), datePicker.getDate(), heureFiche, enseignant.getNumEnseignant())) {
                         JOptionPane.showMessageDialog(null, "Modification réussie !");
                         leModeleFichePresence.modifierMOD(ligne, ligne, fiche);
                     }
			    	
			    }
					});
			

			btnVlider.setFont(new Font("Tahoma", Font.BOLD, 12));
			btnVlider.setBounds(750, 368, 116, 23);
		}
		return btnVlider;
	}

	private JComboBox getCmbNumClasse() {
		  if (cmbNumClasse == null) {
		        cmbNumClasse = new JComboBox<>();
		        cmbNumClasse.addItemListener(new ItemListener() {
		            public void itemStateChanged(ItemEvent arg0) {
		                String numClasse = (String) cmbNumClasse.getSelectedItem();

		                // Vérifie si rien n'est sélectionné
		                if (numClasse == null || numClasse.trim().isEmpty()) {
		                    if (cmbnumEleve != null) cmbnumEleve.removeAllItems();
		                    if (cmbnumero != null) cmbnumero.removeAllItems();
		                    return;
		                }

		                // Vider les combos avant de remplir
		                cmbnumEleve.removeAllItems();
		                cmbnumEleve.addItem("");

		                cmbnumero.removeAllItems();
		                cmbnumero.addItem("");

		                // Charger les élèves de la classe
		                Eleve eleve = new Eleve();
		                lesEleves = eleve.lireRecupEleveParClasse(numClasse);

		                // Remplir les combos
		                for (Eleve e : lesEleves) {
		                    cmbnumEleve.addItem(e.getNumEleve()); // identifiant élève
		                    cmbnumero.addItem(e.getNumero());     // numéro élève
		                }
		            }
		        });



		        // Charger toutes les classes
		        Classe classe = new Classe();
		        lesClasses = classe.lireRecupCRUD();
		        cmbNumClasse.addItem("");
		        for (Classe elem : lesClasses) {
		            cmbNumClasse.addItem(elem.getNumClasse());
		        }
			cmbNumClasse.setBounds(518, 199, 102, 20);
		}
		return cmbNumClasse;
	}

	private void afficher(int numLigne){
		txtnumFiche.setText((String) leModeleFichePresence.getValueAt(numLigne, 0));
		//txtdateFiche.setText((String) leModeleFichePresence.getValueAt(numLigne, 1));
		// Date fiche (colonne 1)
	    Object dateObj = leModeleFichePresence.getValueAt(numLigne, 1);
	    if (dateObj instanceof Date) {
	        datePicker.setDate((Date) dateObj);
	    }
	    
		//txtheureFiche.setText((String) leModeleFichePresence.getValueAt(numLigne, 2));
	 // Heure fiche (colonne 2, String → parse en Date pour le JSpinner)
	    Object heureObj = leModeleFichePresence.getValueAt(numLigne, 2);
	    if (heureObj instanceof String) {
	        try {
	            java.text.SimpleDateFormat sdf = new java.text.SimpleDateFormat("HH:mm");
	            heurePresence.setValue(sdf.parse((String) heureObj));
	        } catch (Exception e) {
	            e.printStackTrace();
	        }
	    }
		cmbnumEnseignant.setSelectedItem(leModeleFichePresence.getValueAt(numLigne, 3));
		txtnomEnseignant.setText((String) leModeleFichePresence.getValueAt(numLigne, 4));
		
		
	}
	

package lan.tovo.note;

import java.sql.Connection;
import java.sql.Statement;
import java.sql.ResultSet;
import java.sql.SQLException;
import javax.swing.JOptionPane;
import java.util.ArrayList;

public class Matiere {
	
	private String numMatiere;
	private String libelleMatiere;
	private String coefficient;
	private Enseignant numEnseignant;
	
	private static Connection laConnexion = Connexion.Konnexion();
	private final ArrayList<Matiere> results = new ArrayList<Matiere>();
	
	public Matiere() {
		
	}

	public Matiere(String numMatiere) {
		this.numMatiere = numMatiere;
	}

	public Matiere(String numMatiere, String libelleMatiere) {
		this.numMatiere = numMatiere;
		this.libelleMatiere = libelleMatiere;
	}

	public Matiere(String numMatiere, String libelleMatiere, String coefficient,
			Enseignant numEnseignant) {
		this.numMatiere = numMatiere;
		this.libelleMatiere = libelleMatiere;
		this.coefficient = coefficient;
		this.numEnseignant = numEnseignant;
	}

	public String getNumMatiere() {
		return numMatiere;
	}

	public void setNumMatiere(String numMatiere) {
		this.numMatiere = numMatiere;
	}

	public String getLibelleMatiere() {
		return libelleMatiere;
	}

	public void setLibelleMatiere(String libelleMatiere) {
		this.libelleMatiere = libelleMatiere;
	}

	public String getCoefficient() {
		return coefficient;
	}

	public void setCoefficient(String coefficient) {
		this.coefficient = coefficient;
	}

	public Enseignant getNumEnseignant() {
		return numEnseignant;
	}

	public void setNumEnseignant(Enseignant numEnseignant) {
		this.numEnseignant = numEnseignant;
	}

//************
	public boolean creerCRUD(String numMatiere, String libelleMatiere, String coefficient, String numEnseignant){
			
		boolean creation = false;
		try{
			Statement state = laConnexion.createStatement();
			String requete = "INSERT INTO Matiere(numMatiere,libelleMatiere,coefficient,"
						+ "numEnseignant )"
						+ "VALUES('"+numMatiere+"','"+libelleMatiere+"','"+coefficient+"','"+numEnseignant+"')";
			
			state.executeUpdate(requete);
			state.close();
			creation=true;
				
		}catch(SQLException e){
			JOptionPane.showMessageDialog(null, "Problčme rencontré :" + e.getMessage(),
				"Résultat",JOptionPane.ERROR_MESSAGE);
		}
		return creation;
	}

	//***
	public ArrayList<Matiere> lireRecupCRUD(){
		try{
				Statement state = laConnexion.createStatement();
							
				ResultSet rs = state.executeQuery("SELECT numMatiere,libelleMatiere,coefficient,"
						+ " Enseignant.numEnseignant, nomEnseignant, prenomEnseignant " 
						+ " FROM Matiere INNER JOIN Enseignant ON Matiere.numEnseignant = Enseignant.numEnseignant"
				);
							
				while (rs.next()){						
					String numMatiere = rs.getString("numMatiere");
					String libelleMatiere = rs.getString("libelleMatiere");
					String coefficient =  rs.getString("coefficient");
					
					String numEnseignant = rs.getString("numEnseignant");
					String nomEnseignant = rs.getString("nomEnseignant");
					String prenomEnseignant = rs.getString("prenomEnseignant");	
					
					results.add(new Matiere(numMatiere,libelleMatiere,coefficient,
						new Enseignant(numEnseignant,nomEnseignant,prenomEnseignant)
					));
								
				}
							
		}catch(SQLException e){
				JOptionPane.showMessageDialog
					(null, "Problčme rencontré : " + e.getMessage(),"ERREUR",JOptionPane.ERROR_MESSAGE);
		}
		return results;
	}
		//***
		
	public ArrayList<Matiere> lireRecupLigne(String innumMatiere){
		try{
			Statement state = laConnexion.createStatement();
			ResultSet rs = state.executeQuery("SELECT numMatiere,libelleMatiere,coefficient,"								
					+ " Enseignant.numEnseignant, nomEnseignant, prenomEnseignant "
					+ " FROM Matiere, Enseignant"
					+ " WHERE numMatiere = '" + innumMatiere + "'");
							
			while (rs.next()){						
				String numMatiere = rs.getString("numMatiere");
				String libelleMatiere = rs.getString("libelleMatiere");
				String coefficient =  rs.getString("coefficient");
				
				String numEnseignant = rs.getString("numEnseignant");
				String nomEnseignant = rs.getString("nomEnseignant");
				String prenomEnseignant = rs.getString("prenomEnseignant");	
				
				results.add(new Matiere(numMatiere,libelleMatiere,coefficient,
					new Enseignant(numEnseignant,nomEnseignant,prenomEnseignant)
				));
								
			}
							
		}catch(SQLException e){
				JOptionPane.showMessageDialog
						(null, "Problčme rencontré : " + e.getMessage(),"ERREUR",JOptionPane.ERROR_MESSAGE);
		}
		return results;
	}

	//***
	
	public boolean modifierCRUD(String numMatiere, String libelleMatiere, String coefficient, String numEnseignant){
			boolean modif = true;
			String requete = null;
			try{
				requete = "UPDATE Matiere SET "
						+ "libelleMatiere ='" +libelleMatiere+ "',"
						+ "coefficient = '" +coefficient+ "',"
						+ "numEnseignant = '" +numEnseignant+ "'"
						+ " WHERE numMatiere = '" +numMatiere + "'";
								
				Statement state = laConnexion.createStatement();
				state.executeUpdate(requete);
				state.close();
			}catch(SQLException e){
				modif = false;
				JOptionPane.showMessageDialog(null, "Modification non effectuée :" + e.getMessage(),
						"Problčme rencontré",JOptionPane.ERROR_MESSAGE);
			}
			return modif;
	}
	
	//***
	public boolean supprimerCRUD(String innumMatiere){
		boolean suppr = true;
		try{
			String requete = "DELETE FROM Matiere "
								+ " WHERE numMatiere = '" + innumMatiere + "'";
			Statement state = laConnexion.createStatement();
			state.executeUpdate(requete);
		}catch(SQLException e){
			suppr = false;
			JOptionPane.showMessageDialog(null, "Suppression non effectuée :" + e.getMessage(),
						"Problčme rencontré",JOptionPane.ERROR_MESSAGE);
		}
		return suppr;
	}
	
	//****
	
	public ArrayList<Matiere> chercherCRUD(String recherche){
			
			String requete = "SELECT numMatiere,numMatiere,coefficient," 
					+ " Enseignant.numEnseignant, Enseignant.nomEnseignant, Enseignant.prenomEnseignant "
					+ " FROM Matiere INNER JOIN Enseignant ON Matiere.numEnseignant = Enseignant.numEnseignant"
					+ " WHERE numMatiere LIKE '%" +recherche+ "%'"
					+ " OR numMatiere LIKE '%" +recherche+ "%'";
			
			try{
				   Statement state=laConnexion.createStatement();
				   ResultSet rs=state.executeQuery(requete);
				   while (rs.next()){						
					   String numMatiere = rs.getString("numMatiere");
						String libelleMatiere = rs.getString("libelleMatiere");
						String coefficient =  rs.getString("coefficient");
						
						String numEnseignant = rs.getString("numEnseignant");
						String nomEnseignant = rs.getString("nomEnseignant");
						String prenomEnseignant = rs.getString("prenomEnseignant");	
						
						results.add(new Matiere(numMatiere,libelleMatiere,coefficient,
							new Enseignant(numEnseignant,nomEnseignant,prenomEnseignant)
						));
						
					}
			   }
			   catch(SQLException e){	
				   JOptionPane.showMessageDialog(null,"Problčme rencontré : "
						   +e.getMessage(),
						   "Résultat",JOptionPane.ERROR_MESSAGE);
			   }
			
			
			return results;
	}
	
	public String getNextNumMatiere() {
		String nextNum = "1";
		try {
			Statement state = laConnexion.createStatement();
			ResultSet rs = state.executeQuery("SELECT MAX (numMatiere) FROM Matiere");
			
			if (rs.next()) {
				String lastNum = rs.getString(1);
				if (lastNum != null){
					int num = Integer.parseInt(lastNum);
					nextNum = String.valueOf(num + 1);
				}
			}
			rs.close();
			state.close();
		}catch (SQLException e) {
			JOptionPane.showMessageDialog(null, "erreur lors de la generation du nuero " + e.getMessage(),
					"ERREUR", JOptionPane.ERROR_MESSAGE); 
		}
		return nextNum;
	}

	

}

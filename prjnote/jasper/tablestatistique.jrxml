	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="numcommune" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT Commune.numcommune, nomcommune, Fokontany.idfoko, nomfoko, 
				SUM(inscrits) as inscr, SUM(votant) as votan , SUM(blancnul) as bl,
				Resultatvote.numparti, nomparti, SUM(voix) as voi,
				(SUM(votant) - SUM(blancnul)) as SE, ROUND(((SUM(voix) * 100) / SUM(votant)),2) as prct
				FROM Commune
				INNER JOIN Fokontany ON Commune.numcommune = Fokontany.numcommune
				INNER JOIN Bureauvote ON Fokontany.idfoko = Bureauvote.idfoko
				INNER JOIN Resultatvote ON Bureauvote.numbv = Resultatvote.numbv
				INNER JOIN Parti ON Parti.numparti = Resultatvote.numparti
				WHERE Commune.numcommune = $P{numcommune} GROUP BY Resultatvote.numparti,Commune.numcommune ;]]>
	</queryString>
	<field name="numcommune" class="java.lang.String"/>
	<field name="nomcommune" class="java.lang.String"/>
	<field name="idfoko" class="java.lang.String"/>
	<field name="nomfoko" class="java.lang.String"/>
	<field name="inscr" class="java.lang.String"/>
	<field name="votan" class="java.lang.String"/>
	<field name="bl" class="java.lang.String"/>
	<field name="numparti" class="java.lang.String"/>

				</textElement>
				<text><![CDATA[Carte Elect.]]></text>
			</staticText>

			<staticText>
				<reportElement x="729" y="2" width="100" height="20"/>
				<textElement >
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[N° Commune]]></text>
			</staticText>

			<staticText>
				<reportElement x="856" y="2" width="100" height="20"/>
				<textElement>
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[Commune]]></text>
